# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Next Auth
# You can generate a new secret on the command line with:
# npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET=""

# Next Auth Discord Provider
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://postgres:password@localhost:5432/nomey-next"

# Mux Video
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_SIGNING_KEY_ID=""
MUX_SIGNING_KEY_SECRET=""
MUX_VIDEO_QUALITY="basic"
MUX_WEBHOOK_SECRET=""

# Meilisearch
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="aSampleMasterKey"

# Resend Email Service
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Nomey <onboarding@resend.dev>"
RESEND_TO_DEV_ADDRESS="" # An email address registered with Resend

# Tolgee Variables
TOLGEE_API_KEY="tolgee_api_key"

# Upstash (Redis)
UPSTASH_REDIS_REST_URL="https://www.upstash_url.com"
UPSTASH_REDIS_REST_TOKEN="upstash_api_key"

# SSE (Server-Sent Events) Configuration
# Core SSE Settings
SSE_ENABLED="true"

# Heartbeat Configuration
SSE_HEARTBEAT_ENABLED="true"
SSE_HEARTBEAT_INTERVAL="30000"
SSE_HEARTBEAT_TIMEOUT="60000"
SSE_MAX_MISSED_PINGS="3"

# Redis Configuration
SSE_REDIS_KEY_PREFIX="sse:"
SSE_CONNECTION_TTL="3600"
SSE_CLEANUP_INTERVAL="300"

# Connection Limits
SSE_MAX_CONNECTIONS="10000"
SSE_MAX_EVENTS_PER_SECOND="1000"
SSE_MAX_PAYLOAD_SIZE="65536"
SSE_CONNECTION_TIMEOUT="300000"

# Feature Flags
SSE_FEATURE_HEARTBEAT="true"
SSE_FEATURE_AUTH="true"
SSE_FEATURE_RATE_LIMITING="true"
SSE_FEATURE_MONITORING="true"
SSE_FEATURE_COMPRESSION="false"

# Monitoring Configuration
SSE_MONITORING_ENABLED="true"
SSE_METRICS_INTERVAL="60000"
SSE_LOG_LEVEL="info"

# Security Configuration
SSE_REQUIRE_AUTH="true"
SSE_ALLOWED_ORIGINS=""
SSE_MAX_CONNECTIONS_PER_USER="10"
SSE_MAX_CONNECTIONS_PER_IP="50"